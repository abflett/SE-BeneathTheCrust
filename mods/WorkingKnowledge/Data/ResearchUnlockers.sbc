      <Model>Models\Items\Datapad_Item.mwm</Model>
      <Components>
        <Component Subtype="WkKnDataFragmentComponent" Count="100" />
      </Components>
      <CriticalComponent Subtype="WkKnDataFragmentComponent" Index="0" />
