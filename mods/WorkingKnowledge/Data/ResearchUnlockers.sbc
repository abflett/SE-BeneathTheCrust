        <Model BuildPercentUpperBound="1.00" File="Models\Items\Datapad_Item.mwm" />
      </BuildProgressModels>
      <DeformationRatio>0.32</DeformationRatio>
      <EdgeType>Light</EdgeType>
      <BuildTimeSeconds>3</BuildTimeSeconds>
      <PCU>1</PCU>
      <IsAirTight>false</IsAirTight>
